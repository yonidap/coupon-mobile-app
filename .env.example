EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# Edge Function secrets (server-side only — NEVER use EXPO_PUBLIC_ prefix)
# ---------------------------------------------------------------------------

# Authorizes cron invocations of the process-reminders Edge Function.
# Set this in the Supabase Dashboard under:
#   Settings → Edge Functions → process-reminders → Secrets
# and in the pg_cron job SQL (see REMINDER_FLOW.md).
# For local development, set it in .env.local (not committed to git).
PROCESS_REMINDERS_SECRET=change-me-to-a-long-random-string

# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically
# by the Supabase Edge Function runtime. Do NOT add them here.